---
import siteData from '../data/site.json';

interface Props {
  title?: string;
}

const { title = siteData.siteName } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style is:global>
    :root {
      --bg-color: #FAFAFA;
      --accent-green: #A8D5BA; /* Pastel Watercolor Green */
      --text-main: #1B3320; /* Soft dark forest green */
      --font-body: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      --font-heading: 'Brush Script MT', cursive; 
    }
    
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg-color); /* Fallback */
      background-image: linear-gradient(rgba(250, 250, 250, 0.92), rgba(250, 250, 250, 0.92)), url('/assets/splash-bg.jpg');
      background-size: cover;
      background-position: center;
      background-attachment: fixed; /* Keeps the background still while scrolling */
      background-repeat: no-repeat;
      color: var(--text-main);
      font-family: var(--font-body);
      min-height: 100vh;
      overflow-x: hidden;
    }
/* Transforms all solid white containers into elegant frosted glass */
    .content-wrapper {
      background: rgba(255, 255, 255, 0.85) !important;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.6);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08) !important;
    }
    h1, h2, h3, .heading-font {
      font-family: var(--font-heading);
      font-weight: normal;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>