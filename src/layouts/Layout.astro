---
import siteData from '../data/site.json';

interface Props {
  title?: string;
}

const { title = siteData.siteName } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style is:global>
    :root {
      --bg-color: #FAFAFA;
      --accent-green: #A8D5BA; /* Pastel Watercolor Green */
      --text-main: #1B3320; /* Soft dark forest green */
      --font-body: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      --font-heading: 'Brush Script MT', cursive; 
    }
    
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg-color);
      color: var(--text-main);
      font-family: var(--font-body);
      min-height: 100vh;
      overflow-x: hidden;
    }

    h1, h2, h3, .heading-font {
      font-family: var(--font-heading);
      font-weight: normal;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>